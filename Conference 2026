<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ICFB UNICAL 2026 | International Conference of Finance and Banking</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --navy: #0a1628;
    --navy2: #112240;
    --gold: #c9933a;
    --gold2: #e8b86d;
    --cream: #f8f4ed;
    --white: #ffffff;
    --gray: #8899aa;
    --light: #eef2f7;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--navy); color: var(--white); overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 3rem;
    background: rgba(10,22,40,0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(201,147,58,0.2);
  }
  .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--gold); letter-spacing: 0.05em; }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; transition: color 0.2s; }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta { background: var(--gold); color: var(--navy); padding: 0.5rem 1.25rem; border-radius: 4px; text-decoration: none; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; transition: background 0.2s; }
  .nav-cta:hover { background: var(--gold2); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    background: linear-gradient(160deg, #0a1628 0%, #0d2545 60%, #0a1628 100%);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201,147,58,0.08) 0%, transparent 70%);
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(201,147,58,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(201,147,58,0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-tag {
    display: inline-block;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border-radius: 2px;
    margin-bottom: 2rem;
    animation: fadeUp 0.8s ease both;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1.15;
    font-weight: 700;
    max-width: 820px;
    animation: fadeUp 0.8s 0.15s ease both;
  }
  .hero h1 span { color: var(--gold); }
  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    margin-top: 1.25rem;
    font-style: italic;
    animation: fadeUp 0.8s 0.25s ease both;
  }
  .hero-theme {
    margin-top: 2rem;
    font-size: 1.05rem;
    color: var(--cream);
    font-weight: 500;
    max-width: 640px;
    animation: fadeUp 0.8s 0.35s ease both;
  }
  .hero-meta {
    display: flex; gap: 2.5rem; margin-top: 2.5rem;
    flex-wrap: wrap; justify-content: center;
    animation: fadeUp 0.8s 0.45s ease both;
  }
  .hero-meta-item { text-align: center; }
  .hero-meta-item .label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray); }
  .hero-meta-item .value { font-size: 1.05rem; font-weight: 600; color: var(--gold2); margin-top: 0.2rem; }
  .hero-btns {
    display: flex; gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap; justify-content: center;
    animation: fadeUp 0.8s 0.55s ease both;
  }
  .btn-primary { background: var(--gold); color: var(--navy); padding: 0.85rem 2rem; border-radius: 4px; text-decoration: none; font-weight: 600; font-size: 0.9rem; letter-spacing: 0.03em; transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: var(--gold2); transform: translateY(-2px); }
  .btn-outline { border: 1px solid rgba(255,255,255,0.3); color: var(--white); padding: 0.85rem 2rem; border-radius: 4px; text-decoration: none; font-weight: 500; font-size: 0.9rem; transition: border-color 0.2s, transform 0.15s; }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }
  .countdown { display: flex; gap: 1.5rem; margin-top: 3rem; animation: fadeUp 0.8s 0.65s ease both; }
  .cd-box { text-align: center; }
  .cd-num { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold); line-height: 1; }
  .cd-lbl { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray); margin-top: 0.3rem; }
  .cd-sep { font-size: 2rem; color: var(--gold); opacity: 0.4; align-self: flex-start; padding-top: 0.2rem; }

  /* SECTIONS */
  section { padding: 5rem 2rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-tag { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); margin-bottom: 0.75rem; }
  .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 700; line-height: 1.2; }
  .section-divider { width: 50px; height: 2px; background: var(--gold); margin: 1.25rem 0 2rem; }

  /* ABOUT */
  .about { background: var(--navy2); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-text p { color: rgba(255,255,255,0.72); line-height: 1.8; margin-bottom: 1rem; font-size: 0.95rem; }
  .about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .stat-box { background: rgba(201,147,58,0.08); border: 1px solid rgba(201,147,58,0.2); border-radius: 8px; padding: 1.5rem; text-align: center; }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--gold); font-weight: 700; }
  .stat-lbl { font-size: 0.8rem; color: var(--gray); margin-top: 0.3rem; }

  /* DATES */
  .dates { background: var(--navy); }
  .dates-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; }
  .date-card { background: var(--navy2); border: 1px solid rgba(201,147,58,0.15); border-radius: 10px; padding: 1.75rem; position: relative; overflow: hidden; transition: border-color 0.2s, transform 0.2s; }
  .date-card:hover { border-color: var(--gold); transform: translateY(-4px); }
  .date-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gold); opacity: 0; transition: opacity 0.2s; }
  .date-card:hover::before { opacity: 1; }
  .date-card .date { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--gold); font-weight: 700; }
  .date-card .event { font-size: 0.95rem; font-weight: 600; margin-top: 0.5rem; }
  .date-card .desc { font-size: 0.82rem; color: var(--gray); margin-top: 0.4rem; }

  /* THEMES */
  .themes { background: var(--navy2); }
  .themes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; margin-top: 2.5rem; }
  .theme-item { display: flex; gap: 1rem; align-items: flex-start; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; padding: 1.25rem; transition: border-color 0.2s, background 0.2s; }
  .theme-item:hover { border-color: rgba(201,147,58,0.3); background: rgba(201,147,58,0.05); }
  .theme-num { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--gold); font-weight: 700; min-width: 28px; }
  .theme-text { font-size: 0.88rem; color: rgba(255,255,255,0.8); line-height: 1.5; }

  /* SPEAKERS */
  .speakers { background: var(--navy); }
  .speakers-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; }
  .speaker-card { background: var(--navy2); border: 1px solid rgba(201,147,58,0.12); border-radius: 12px; padding: 2rem 1.5rem; text-align: center; transition: transform 0.2s, border-color 0.2s; }
  .speaker-card:hover { transform: translateY(-5px); border-color: var(--gold); }
  .speaker-avatar { width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--gold); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--gold); overflow: hidden; background: linear-gradient(135deg, rgba(201,147,58,0.3), rgba(201,147,58,0.1)); }
  .speaker-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .speaker-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 600; }
  .speaker-role { font-size: 0.8rem; color: var(--gold); margin-top: 0.3rem; }
  .speaker-inst { font-size: 0.78rem; color: var(--gray); margin-top: 0.2rem; }

  /* REGISTRATION */
  .registration { background: var(--navy2); }
  .reg-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.25rem; margin-top: 2.5rem; }
  .reg-card { background: var(--navy); border: 1px solid rgba(201,147,58,0.15); border-radius: 10px; padding: 1.75rem 1.25rem; text-align: center; transition: transform 0.2s, border-color 0.2s; }
  .reg-card.featured { border-color: var(--gold); background: rgba(201,147,58,0.06); }
  .reg-card:hover { transform: translateY(-4px); border-color: var(--gold); }
  .reg-type { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray); }
  .reg-price { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--gold); font-weight: 700; margin: 0.75rem 0 0.25rem; }
  .reg-note { font-size: 0.78rem; color: var(--gray); }
  .bank-info { margin-top: 3rem; background: rgba(201,147,58,0.08); border: 1px solid rgba(201,147,58,0.25); border-radius: 10px; padding: 2rem; }
  .bank-info h3 { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--gold); margin-bottom: 1rem; }
  .bank-detail { display: flex; justify-content: space-between; padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.07); font-size: 0.9rem; }
  .bank-detail:last-child { border-bottom: none; }
  .bank-detail .key { color: var(--gray); }
  .bank-detail .val { font-weight: 500; }

  /* CALL FOR PAPERS */
  .cfp { background: var(--navy); }
  .cfp-box { background: linear-gradient(135deg, rgba(201,147,58,0.1), rgba(201,147,58,0.03)); border: 1px solid rgba(201,147,58,0.3); border-radius: 12px; padding: 3rem; text-align: center; }
  .cfp-box h2 { font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 1rem; }
  .cfp-box p { color: rgba(255,255,255,0.7); max-width: 600px; margin: 0 auto 2rem; line-height: 1.8; font-size: 0.95rem; }
  .cfp-email { font-size: 1.1rem; color: var(--gold); font-weight: 600; margin-bottom: 2rem; display: block; }

  /* CONTACT */
  .contact { background: var(--navy2); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
  .contact-item { display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 1.5rem; }
  .contact-icon { width: 40px; height: 40px; background: rgba(201,147,58,0.1); border: 1px solid rgba(201,147,58,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
  .contact-info .label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray); }
  .contact-info .value { font-size: 0.95rem; margin-top: 0.2rem; }

  /* FOOTER */
  footer { background: #060e1a; padding: 2.5rem; text-align: center; border-top: 1px solid rgba(201,147,58,0.15); }
  footer p { font-size: 0.82rem; color: var(--gray); }
  footer .gold { color: var(--gold); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.25rem; }
    .nav-links { display: none; }
    .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hero-meta { gap: 1.5rem; }
  }
</style>
</head>
